venv/
*.pyc
settings.py

# For a Django project, a typical .gitignore looks like this:
# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environment
venv/
env/
ENV/
.venv/

# Django stuff
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/

# Static files (if collected)
staticfiles/

# Environment variables
.env
.env.*

# Distribution / packaging
build/
dist/
*.egg-info/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Testing / coverage
.coverage
api.md
htmlcov/
.pytest_cache/

# Migrations (optional — many teams keep them)
# */migrations/*
# !*/migrations/__init__.py